# ── Database ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/qahal?schema=public

# ── Auth ──
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Email (Resend) ──
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@qahal.app

# ── SMS (Twilio) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── Payments ──
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ── File Storage (S3 / R2) ──
S3_BUCKET=qahal-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=xxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxx
S3_ENDPOINT=  # Leave empty for AWS, set for R2/MinIO

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Firebase (Push Notifications) ──
FIREBASE_PROJECT_ID=qahal-app
FIREBASE_PRIVATE_KEY=xxxxxxxxxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@qahal-app.iam.gserviceaccount.com

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NODE_ENV=development
